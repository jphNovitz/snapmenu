{# stimulus_controller('nav') was here #}
<div>

    <div class="navbar bg-base-100 shadow-sm sticky top-0 z-50">

        <div class="navbar-start">
            <a href="{{ path('app_infos_contact') }}"
               class="btn btn-ghost btn-square"
               title="Code QR">
                {{ ux_icon('lucide:qr-code', {class: 'w-6 h-6'}) }}
            </a>
        </div>

        <div class="navbar-center">
            {% if globalStore is defined %}
                {% if globalStore.logoName is not null %}
                    <a href="{{ path('app_menu', {slug: globalStore.slug}) }}">
                        <img src="{{ asset('images/stores/' ~ globalStore.logoName) }}"
                             class="h-10"
                             alt="{{ globalStore.name }}">
                    </a>
                {% else %}
                    <a href="{{ path('app_menu') }}" class="text-xl font-bold capitalize">
                        {{ globalStore.name }}
                    </a>
                {% endif %}
            {% else %}
                <a href="{{ path('app_default') }}" class="text-xl font-bold">
                    Snap<strong>Menu</strong>
                </a>
            {% endif %}
        </div>

        <div class="navbar-end">
            {% if globalStore is defined and globalStore.phoneNumber is not null %}
                <a href="tel:{{ globalStore.phoneNumber }}"
                   class="btn btn-ghost btn-square"
                   title="{{ globalStore.phoneNumber }}">
                    {{ ux_icon('lucide:phone', {class: 'w-6 h-6'}) }}
                </a>
            {% else %}
                <span class="btn btn-ghost btn-square opacity-30 cursor-default">
                    {{ ux_icon('lucide:phone', {class: 'w-6 h-6'}) }}
                </span>
            {% endif %}
        </div>

    </div>

    {% include '_partial/_header/_nav.html.twig' %}

</div>
