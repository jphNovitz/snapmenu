<!DOCTYPE html>
<html lang="fr_BE" class="scroll-smooth" data-theme="court-minimal" >
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{% block title %}Welcome!{% endblock %}</title>
    <meta name="description" content="{% block description %}Welcome!{% endblock %}">
    <link rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

    {% endblock %}

    {% block javascripts %}
    {% block importmap %}
    {{ importmap('app') }}
    {% endblock %}
    {% endblock %}
  </head>
  <body class="w-screen overflow-x-hidden min-h-screen bg-base-300 text-base">
    <main class="w-full md:max-w-7xl mx-auto bg-base-200">
      {% include '_partial/_header/_header.html.twig' %}
      <div class="p-4">{% block body %}{% endblock %}</div>

      <footer class="bg-neutral text-neutral-content w-full">
        <div class="container mx-auto px-5 pt-10 pb-8">

          <p class="text-5xl font-black lowercase tracking-tight mb-8">
            à bientôt.
            <span class="bg-primary text-primary-content rotate-[-2deg] px-2 rounded-md inline-block">snap.</span>
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">

            <div>
              <p class="font-mono text-xs uppercase tracking-widest opacity-55 mb-2">Restaurant</p>
              {% if globalStore is defined and globalStore.name %}
                <p class="font-bold">{{ globalStore.name }}</p>
              {% endif %}
            </div>

            <div>
              <p class="font-mono text-xs uppercase tracking-widest opacity-55 mb-2">Contact</p>
              {% if globalStore is defined %}
                {% if globalStore.phoneNumber %}
                  <a href="tel:{{ globalStore.phoneNumber }}" class="block hover:underline">{{ globalStore.phoneNumber }}</a>
                {% endif %}
                {% if globalStore.email %}
                  <a href="mailto:{{ globalStore.email }}" class="block hover:underline text-sm opacity-80">{{ globalStore.email }}</a>
                {% endif %}
              {% endif %}
            </div>

            <div>
              <p class="font-mono text-xs uppercase tracking-widest opacity-55 mb-2">Adresse</p>
              {% if globalStore is defined and globalStore.streetName %}
                <address class="not-italic text-sm leading-relaxed">
                  {{ globalStore.streetName }} {{ globalStore.houseNumber }}<br>
                  {{ globalStore.postCode }} {{ globalStore.city }}
                </address>
              {% endif %}
            </div>

            <div>
              <p class="font-mono text-xs uppercase tracking-widest opacity-55 mb-2">Propulsé par</p>
              <a href="https://jphiweb.be" class="font-bold hover:underline" target="_blank" rel="noopener noreferrer">jphiweb.be</a>
              <p class="text-xs opacity-55 mt-2">© {{ 'now'|date('Y') }}</p>
            </div>

          </div>

        </div>
      </footer>
    </main>

</html>
