{% extends 'admin/layout/page.html.twig' %}

{% block title %}Category{% endblock %}

{% block page_header %}
    <a href="{{ path('admin_category_index') }}">back to list</a>
{% endblock %}

{% block page_body %}
    <h1>Category</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Name</th>
                <td>{{ category.name }}</td>
            </tr>
            <tr>
                <th>Ordre</th>
                <td>{{ category.rowOrder }}</td>
            </tr>
            <tr>
                <th>Active</th>
                <td>{{ category.active ? 'Oui' : 'Non' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('admin_category_edit', {'id': category.id}) }}">edit</a>

    {{ include('admin/category/_delete_form.html.twig') }}
{% endblock %}
