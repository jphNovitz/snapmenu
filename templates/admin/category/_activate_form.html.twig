<div class="{#w-32 border border-gray-400 rounded-md p-0 flex items-center {% if button_label == 'button.activate' %} justify-start {% else %}justify-end {% endif %}#}">
    <form method="post" action="{{ path('admin_category_activate', {'id': category.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('activate' ~ category.id) }}">
        {% if category.isActive %}
            <button
                type="submit"
                title="Categorie active"
                class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800"
            >
                Active
            </button>
{#            class="w-28 border bg-gray-200 border-gray-400  text-gray-400 rounded-md px-4 py-1 m-0"#}
        {% else %}
            <button
                type="submit"
                title="Categorie inactive"
                class="inline-flex items-center rounded-full bg-gray-200 px-3 py-1 text-sm font-medium text-gray-700"
            >
                Inactive
            </button>

{#            class="w-28 border bg-green-600 text-green-50 rounded-md px-4 py-1 m-0"#}
                {% endif %}
{#            {{ button_label|default('button.activate')|trans }}#}

    </form>
</div>
