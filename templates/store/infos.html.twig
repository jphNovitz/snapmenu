{% extends 'base.html.twig' %}
{% block title %}{{ globalStore.name }}{% endblock %}
{% block description %}{% trans %}opening_hours.header{% endtrans %}{% endblock %}
{% block body %}

    {% set uri = 'snapmenu.be' ~ path('app_menu', {slug: globalStore.slug}) %}
    {% set menuUrl = absolute_url(path('app_menu', {slug: globalStore.slug})) %}

    <div class="min-h-screen flex flex-col items-center justify-center gap-8 px-4 py-12">

        <a href="{{ path('app_menu', {slug: globalStore.slug}) }}"
           class="btn btn-ghost btn-sm self-start absolute top-20 left-4">
            {{ ux_icon('lucide:arrow-left', {class: 'w-4 h-4'}) }}
            {% trans %}nav.menu{% endtrans %}
        </a>

        <h1 class="text-2xl font-bold capitalize">{{ globalStore.name }}</h1>

        <div class="card bg-base-100 shadow-md w-fit">
            <div class="card-body items-center gap-4 p-6">
                <img src="{{ qr_code_url(uri) }}"
                     class="w-56 h-56"
                     alt="{{ globalStore.name }} — code QR">
                <a href="{{ menuUrl }}"
                   class="link link-neutral text-sm text-center break-all">
                    {{ menuUrl }}
                </a>
            </div>
        </div>

        <div class="text-center space-y-1 text-base-content/60 text-sm">
            <p class="capitalize">{{ globalStore.streetName }} {{ globalStore.houseNumber }}, {{ globalStore.postCode }} {{ globalStore.city }}</p>
            {% if globalStore.phoneNumber is not null %}
                <p>
                    <a href="tel:{{ globalStore.phoneNumber }}" class="link link-neutral">
                        {{ globalStore.phoneNumber }}
                    </a>
                </p>
            {% endif %}
        </div>

        <a href="{{ path('app_message_send', {slug: globalStore.slug}) }}"
           class="btn btn-outline btn-sm">
            {% trans %}button.message{% endtrans %}
        </a>

    </div>

{% endblock %}
