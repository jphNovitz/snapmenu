<section class="bg-base-100 border-b-[2.5px] border-base-content px-4 py-6 md:px-7 md:py-9">

    <h1 class="text-[44px] md:text-[72px] font-black lowercase tracking-[-0.045em] leading-[0.92] mb-1.5">
        {{ globalStore.name }}<span class="text-secondary">!</span>
    </h1>

    {% if globalStore.description is not null %}
        <p class="text-sm md:text-base font-medium leading-relaxed max-w-[460px]">
            {{ globalStore.description }}
        </p>
    {% endif %}

    <div class="inline-flex flex-wrap gap-1.5 mt-3">
        <span class="badge h-auto rounded-full bg-white border-2 border-base-content font-mono text-[11px] font-semibold shadow-[2px_2px_0_0_var(--color-base-content)] px-2.5 py-1">
            <span class="text-success mr-1">●</span>ouvert
        </span>
        {% if globalStore.streetName is not null %}
            <span class="badge h-auto rounded-full bg-white border-2 border-base-content font-mono text-[11px] font-semibold shadow-[2px_2px_0_0_var(--color-base-content)] px-2.5 py-1">
                {{ globalStore.streetName }} {{ globalStore.houseNumber }} · {{ globalStore.postCode }}
            </span>
        {% endif %}
    </div>

    
</section>
