<div class="hero min-h-[60vh]">
    <div class="hero-content flex-col lg:flex-row-reverse gap-12">

        {% if globalStore.imageName is not null %}
            <img src="{{ asset('images/store/' ~ globalStore.imageName) }}"
                 class="max-w-sm w-full rounded-lg shadow-lg object-cover"
                 alt="{{ globalStore.name }}">
        {% endif %}

        <div>
            <h1 class="text-4xl lg:text-5xl font-bold capitalize">
                {{ globalStore.name }}
            </h1>
            {% if globalStore.description is not null %}
                <p class="py-6 text-base-content/70 max-w-md">
                    {{ globalStore.description }}
                </p>
            {% endif %}
            <a href="{{ path('app_menu') }}" class="btn btn-primary">
                {% trans %}cta.primary{% endtrans %}
            </a>
        </div>

    </div>
</div>
